// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// CORE IDENTITY & ORGANISATIONS
// -----------------------------

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  firstName    String
  lastName     String

  organisation   Organisation? @relation(fields: [organisationId], references: [id])
  organisationId Int?

  defaultApp   App? @relation("UserDefaultApp", fields: [defaultAppId], references: [id])
  defaultAppId Int?

  roles       UserRole[]
  memberships Membership[]

  // Auth models
  accounts Account[]
  sessions Session[]

  // App-specific projections (1–1)
  membershipDashboardMember MembershipDashboardMember? @relation("UserDashboardMember")

  // Audit log relation (actor)
  auditLogs       AuditLog[]              @relation("AuditActor")
  workExperiences StudentWorkExperience[] @relation("UserWorkExperiences")
  studentProjects StudentProjects[]       @relation("StudentProjects")
  studentSkills   StudentSkill[]          @relation("StudentSkills")
  
  // issue #14 needs seed student has studentprofile and consent 
  // so i create two model and make those models relate to user model
  studentProfile StudentProfile?
  consents       Consent[]

  studentUniversities        StudentUniversity[]         @relation("StudentUniversity")
  studentAcheivementTags     StudentAcheivementTag[]     @relation("StudentAcheivementTag")
  studentPersonalInformation StudentPersonalInformation?
  studentSocialLinks         StudentSocialLink[]

  // Talent platform relations (Issue #13)
  studentCompanyConsents     StudentCompanyConsent[]      @relation("StudentConsents")
  jobPostings                JobPosting[]                 @relation("JobPostingCreator")
  adminRecsAsStudent         AdminRecommendation[]        @relation("RecommendedStudent")
  adminRecsAsAdmin           AdminRecommendation[]        @relation("RecommendingAdmin")
  appSuspensions             AppSuspension[]
  studentCVs                 StudentCV[]
}

model Organisation {
  id          Int              @id @default(autoincrement())
  name        String
  slug        String           @unique
  type        OrganisationType
  status      CompanyStatus    @default(APPROVED)
  users       User[]
  memberships Membership[]

  // Talent platform relations
  studentCompanyConsents StudentCompanyConsent[]
  jobPostings            JobPosting[]
  adminRecommendations   AdminRecommendation[]
}

/// Company lifecycle status — controls recruiter access gating.
/// PENDING blocks access until admin approves. SUSPENDED/BANNED for moderation.
enum CompanyStatus {
  PENDING
  APPROVED
  SUSPENDED
  BANNED
}

enum OrganisationType {
  UNIVERSITY
  INDUSTRY
  OTHER
}

// ROLES & MEMBERSHIPS
// --------------------

model Role {
  id    Int    @id @default(autoincrement())
  key   String @unique // "ADMIN", "STUDENT", "RECRUITER"
  label String

  userRoles      UserRole[]
  appAccessRules AppAccessRule[]
}

model UserRole {
  id     Int    @id @default(autoincrement())
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role   @relation(fields: [roleId], references: [id])
  roleId Int

  @@unique([userId, roleId])
}

model MembershipTier {
  id    Int    @id @default(autoincrement())
  key   String @unique // "BRONZE", "SILVER", "GOLD", "PLATINUM"
  label String
  rank  Int // 1=Bronze, 2=Silver, 3=Gold, 4=Platinum

  memberships    Membership[]
  appAccessRules AppAccessRule[]
}

model Membership {
  id     Int    @id @default(autoincrement())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  organisation   Organisation @relation(fields: [organisationId], references: [id])
  organisationId Int

  membershipTier   MembershipTier @relation(fields: [membershipTierId], references: [id])
  membershipTierId Int

  isActive Boolean @default(true)

  // Mirrors YAML fields
  status      String    @default("active")
  managerName String?
  expiry      DateTime?

  // 1–1 relation to dashboard projection
  dashboardEntry MembershipDashboardMember? @relation("MembershipDashboardEntry")

  @@index([userId])
  @@index([organisationId])
  @@index([membershipTierId])
}

// APP REGISTRY & ACCESS RULES
// ---------------------------

model App {
  id          Int     @id @default(autoincrement())
  key         String  @unique // "MEMBERSHIP_DASHBOARD", "IXN", "TALENT_DISCOVERY"
  name        String
  basePath    String // e.g. "/apps/membership"
  isInternal  Boolean @default(true)
  externalUrl String?
  description String?

  appAccessRules AppAccessRule[]

  usersDefaultApp User[] @relation("UserDefaultApp")
}

model AppAccessRule {
  id    Int @id @default(autoincrement())
  app   App @relation(fields: [appId], references: [id])
  appId Int

  role   Role? @relation(fields: [roleId], references: [id])
  roleId Int?

  minMembershipTier   MembershipTier? @relation(fields: [minMembershipTierId], references: [id])
  minMembershipTierId Int?

  accessType AppAccessType @default(ALLOW)

  @@index([roleId])
  @@index([minMembershipTierId])
}

enum AppAccessType {
  ALLOW
  DENY
}

// MEMBERSHIP DASHBOARD MODULE (NORMALISED VIEW)
model MembershipDashboardMember {
  id Int @id @default(autoincrement())

  // Link back to canonical data (optional, but at most one each)
  user   User?   @relation("UserDashboardMember", fields: [userId], references: [id])
  userId String? @unique

  membership   Membership? @relation("MembershipDashboardEntry", fields: [membershipId], references: [id])
  membershipId Int?        @unique

  // YAML id for easy mapping
  memberKey String @unique // e.g. "chanel", "microsoft"

  // App-specific fields only
  redeemedBenefitCodes String[] // ["B03", "B08", ...]

  @@index([membershipId])
}

// AUTH MODELS (NextAuth-style)
// ----------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// AUDIT LOG
// ---------

model AuditLog {
  id String @id @default(cuid())

  entityType String
  entityId   String

  action String // "CREATE", "UPDATE", "DELETE", "LOGIN", ...

  actor   User?   @relation("AuditActor", fields: [actorId], references: [id])
  actorId String?

  timestamp DateTime @default(now())
  data      Json?

  ipAddress String?
  userAgent String?

  @@index([entityType, entityId])
  @@index([actorId])
}

model StudentWorkExperience {
  id     String @id @default(cuid())
  userId String // ← Direct link to User instead of StudentProfile

  company     String
  title       String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  location    String?

  user User @relation("UserWorkExperiences", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StudentProjects {
  id     String @id @default(cuid())
  userId String

  title       String
  description String?
  projectLink String?
  startDate   DateTime?
  endDate     DateTime?

  user User @relation("StudentProjects", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StudentSkill {
  id     String @id @default(cuid())
  userId String

  name      String
  createdAt DateTime @default(now())

  user User @relation("StudentSkills", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model StudentProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio    String?
}

model Consent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 例如 "PRIVACY_POLICY"
  accepted  Boolean
  createdAt DateTime @default(now())
}
model StudentUniversity {
  id             String    @id @default(cuid())
  userId         String
  universityName String
  fieldOfStudy   String
  grade          String?
  degreeProgram  String
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation("StudentUniversity", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StudentAcheivementTag {
  id     String @id @default(cuid())
  userId String

  name      String
  createdAt DateTime @default(now())

  user User @relation("StudentAcheivementTag", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model StudentPersonalInformation {
  id     String @id @default(cuid())
  userId String @unique

  dateOfBirth DateTime?
  gender      String?

  phoneCode   String?
  phoneNumber String?

  designation String?

  address1   String?
  address2   String?
  country    String?
  state      String?
  city       String?
  postalCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum SocialPlatform {
  LINKEDIN
  FACEBOOK
  GITHUB
  TWITTER
}

model StudentSocialLink {
  id       String         @id @default(cuid())
  userId   String
  platform SocialPlatform
  url      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
}

// ─────────────────────────────────────────────
// TALENT PLATFORM MODELS (Issue #13 — complete)
// ─────────────────────────────────────────────

/// Per-company visibility consent. A student grants or revokes consent
/// for a specific company to view their profile. Recruiters only see
/// students who have consented to their organisation.
model StudentCompanyConsent {
  id        String   @id @default(cuid())
  studentId String
  companyId Int
  consented Boolean  @default(false)
  updatedAt DateTime @updatedAt

  student User         @relation("StudentConsents", fields: [studentId], references: [id], onDelete: Cascade)
  company Organisation @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([studentId, companyId])
  @@index([companyId])
}

/// A job posted by a recruiter on behalf of their organisation.
/// Visible to students based on tier-gated access rules.
model JobPosting {
  id               String    @id @default(cuid())
  organisationId   Int
  createdByUserId  String
  title            String
  description      String
  location         String
  salaryBand       String?
  roleType         String
  postedAt         DateTime  @default(now())
  expiresAt        DateTime?
  isActive         Boolean   @default(true)

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("JobPostingCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([organisationId])
  @@index([createdByUserId])
  @@index([isActive, postedAt])
}

/// Admin-curated recommendation linking a student to a firm.
/// Each firm sees only their own recommended students. Revocable
/// by setting revokedAt — no unique constraint; dedup in service layer.
model AdminRecommendation {
  id        String    @id @default(cuid())
  studentId String
  firmId    Int
  adminId   String
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  student User         @relation("RecommendedStudent", fields: [studentId], references: [id], onDelete: Cascade)
  firm    Organisation @relation(fields: [firmId], references: [id], onDelete: Cascade)
  admin   User         @relation("RecommendingAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([firmId, revokedAt])
  @@index([studentId])
  @@index([adminId])
}

/// Per-app suspension record. Scoped to a single app key so that
/// suspending a user from talent-discovery does not affect their
/// membership dashboard access.
model AppSuspension {
  id          String    @id @default(cuid())
  userId      String
  appKey      String
  reason      String
  suspendedAt DateTime  @default(now())
  liftedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, appKey])
}

/// A CV document uploaded by a student. Storage backend is abstracted
/// behind CVStorageService — fileUrl may point to S3, GDrive, or any
/// future provider. Multiple CVs per student are supported.
model StudentCV {
  id         String   @id @default(cuid())
  userId     String
  label      String
  fileUrl    String
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
